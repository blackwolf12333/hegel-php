{
    "name": "blackwolf12333/hegel-php",
    "description": "PHP client for Hegel property-based testing",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
          "type": "vcs",
          "url": "git@github.com:blackwolf12333/infection.git",
          "no-api": true
        }
      ],
    "require": {
        "php": "^8.4",
        "spomky-labs/cbor-php": "^3.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "carthage-software/mago": "^1.20.1",
        "infection/infection": "dev-peter/mago"
    },
    "autoload": {
        "psr-4": {
            "Hegel\\": "src/Hegel/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hegel\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
